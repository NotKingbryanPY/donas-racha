// ============================================================
//  CORS — preflight OPTIONS
// ============================================================
function doOptions(e) {
  return ContentService.createTextOutput('')
    .setMimeType(ContentService.MimeType.TEXT);
}

function corsResponse(data) {
  const output = ContentService.createTextOutput(JSON.stringify(data))
    .setMimeType(ContentService.MimeType.JSON);
  return output;
}

// ============================================================
//  ROUTER PRINCIPAL
// ============================================================
function doGet(e) {
  const params = e.parameter;
  const action = params.action || '';

  if (action === 'verificarPassword') {
    const pass = params.password || '';
    return corsResponse({ ok: pass === APP_PASSWORD });
  }

  if (action === 'getPublicData') {
    // Alias de getRanking para compatibilidad con el frontend
    return corsResponse(apiGetRanking({ limit: 10 }));   // era jsonResponse
  }

  // aquí va el resto del switch que ya tenías
  let result;
  switch (action) {
    case 'getCliente':       result = apiGetCliente(params);       break;
    case 'buscarCliente':    result = apiBuscarCliente(params);    break;
    case 'getRanking':       result = apiGetRanking(params);       break;
    case 'getStats':         result = apiGetStats(params);         break;
    case 'getTodosClientes': result = apiGetTodosClientes(params); break;
    case 'getConfig':        result = apiGetConfig(params);        break;
    default:
      result = { ok: true, message: 'Donas Racha API activa 🍩' };
  }

  return corsResponse(result);  // era jsonResponse  // era jsonResponse
}


function doPost(e) {
  try {
    const body   = JSON.parse(e.postData.contents);
    const action = body.action || '';
    let result;

    switch (action) {
      case 'registrarCompra': result = apiRegistrarCompra(body); break;
      case 'nuevoCliente':    result = apiNuevoCliente(body);    break;
      case 'eliminarCliente': result = apiEliminarCliente(body); break;
      case 'saveConfig':      result = apiSaveConfig(body);      break;
      default:
        result = { ok: false, error: 'Acción desconocida: ' + action };
    }

    return corsResponse(result);
  } catch (err) {
    return corsResponse({ ok: false, error: err.message });
  }
}

